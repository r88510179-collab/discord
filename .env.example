# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_server_id_for_fast_dev_registration

# AI providers (configure at least one)
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# Sports data / grading
ODDS_API_KEY=

# Twitter / X (optional)
TWITTER_BEARER_TOKEN=

# Persistence
DB_PATH=/data/bettracker.db
DEFAULT_UNIT_SIZE=25
DEFAULT_BANKROLL=1000

# Runtime / Fly
NODE_ENV=production
PORT=3000
AUTO_GRADE_INTERVAL_MINUTES=15

# Optional channel routing
PICKS_CHANNEL_IDS=
DASHBOARD_CHANNEL_ID=
TWITTER_CAPPER_MAP=
CAPPER_CHANNEL_MAP=
