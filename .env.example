# ── Discord ──────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_server_id

# ── Anthropic (Claude AI) ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── The Odds API (free tier: 500 req/month) ──────────
# Sign up: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key

# ── Twitter / X (optional — for capper tracking) ─────
# Apply at: https://developer.x.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── Bot Settings ─────────────────────────────────────
DEFAULT_UNIT_SIZE=25
DEFAULT_BANKROLL=1000
AUTO_GRADE_INTERVAL_MINUTES=15
PICKS_CHANNEL_ID=channel_id_for_auto_parsing

# ── 🔄 re-ingest reaction (handlers/messageHandler.js reingestSlipMessage) ──
# Emoji the OWNER_ID operator reacts with on a HUMAN_SUBMISSION_CHANNEL_IDS slip
# to re-fetch + re-extract it (bets-only vision path) and stage fresh to the War
# Room. Defaults to 🔄 when unset; override only to use a different trigger emoji.
REINGEST_EMOJI=

# ── OCR-first slip extraction (services/localOcr.js + services/ocrFirst.js) ──
# Surface Pro RapidOCR microservice (zonetracker-ocr). See docs/specs/ocr-first.md.
# Wired into the slip path behind OCR_FIRST_MODE (services/ocrFirstWiring.js).
OCR_FIRST_MODE=off                        # off | shadow | cutover. off=no OCR calls (default).
                                          #   shadow=fire-and-forget compare vs Gemini (no behavior change).
                                          #   cutover=use validated OCR parse, fall back to Gemini otherwise.
SGP_HOLD_MODE=off                         # SGP 2b drop→hold (design D2), SEPARATE from OCR_FIRST_MODE — read
                                          # per call (flip without restart). off (default) = byte-identical.
                                          #   shadow = measure at the vision-failure seam (ocr_sgp_hold_shadow),
                                          #   enforce = gate-PASS SGP slips hold for review with OCR legs;
                                          # FAIL/error always keeps today's behavior. docs/specs/ocr-first.md §8.5.
OCR_SERVICE_URL=                          # base URL of the OCR service (e.g. https://<funnel-host>:8443)
OCR_SERVICE_TOKEN=                        # bearer token for POST /ocr
OCR_TIMEOUT_MS=8000                       # per-request abort deadline (~3s OCR + headroom); cutover total budget
OCR_SHADOW_TIMEOUT_MS=15000               # shadow-only image-fetch abort deadline (falls back to OCR_TIMEOUT_MS)
OCR_IMAGE_MAX_BYTES=10485760              # hard cap on fetched slip-image bytes (10MB); content-length + streaming
OCR_PARSE_MODEL=llama-3.3-70b-versatile   # Groq model for the OCR-text → bet parse (falls back to GROQ_MODEL)
OCR_PARSE_TEMPERATURE=0                    # Groq temperature for the parse
OCR_CIRCUIT_BREAKER_FAILS=3               # consecutive failures that open the breaker
OCR_CIRCUIT_BREAKER_COOLDOWN_MS=60000     # how long the breaker stays open
